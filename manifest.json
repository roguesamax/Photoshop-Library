{
  "manifestVersion": 5,
  "id": "com.kitlibrary.uv-preserve",
  "name": "KIT UV Library",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "25.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "kit-uv-library-panel",
      "label": {
        "default": "KIT UV Library"
      },
      "minimumSize": {
        "width": 320,
        "height": 480
      },
      "maximumSize": {
        "width": 1400,
        "height": 1600
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 640
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 760
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "allowCodeGenerationFromStrings": false
  }
}
